    { "type": "Binding", "target": "InfDeclaracaoPrestacaoServico.Servico.Valores.ValorServicos", "source": "Values.ServicesAmount", "format": "F2" },
    { "type": "Binding", "target": "InfDeclaracaoPrestacaoServico.Servico.IssRetido", "sourceType": "constant", "constantValue": "2" },
