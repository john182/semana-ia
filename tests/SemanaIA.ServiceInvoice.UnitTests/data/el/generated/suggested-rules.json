{
  "provider": "el",
  "version": "1.01",
  "formatting": {
    "LogradouroTipo": {
      "maxLength": 10
    },
    "Logradouro": {
      "maxLength": 130
    },
    "LogradouroNumero": {
      "maxLength": 10
    },
    "LogradouroComplemento": {
      "maxLength": 60
    },
    "Bairro": {
      "maxLength": 70
    },
    "CodigoMunicipio": {
      "maxLength": 7
    },
    "Municipio": {
      "maxLength": 100
    },
    "Uf": {
      "padLeft": 2,
      "padChar": "0",
      "maxLength": 2
    },
    "Cep": {
      "maxLength": 10
    }
  },
  "rootComplexTypeName": "tcEndereco",
  "rootElementName": "LoteRps",
  "bindings": {
    "Bairro": "Borrower.Address.District",
    "CodigoMunicipio": "Provider.MunicipalityCode",
    "Municipio": "TODO: manual mapping required",
    "Uf": "Borrower.Address.State",
    "Cep": "Borrower.Address.PostalCode"
  }
}